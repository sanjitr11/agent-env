{
  "name": "@agent-env/cli",
  "version": "0.1.0",
  "description": "Persistent specialized agent environment for solo founders — built on Claude Code",
  "type": "module",
  "bin": {
    "agent-env": "dist/bin/agent-env.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "tsx bin/agent-env.ts",
    "build": "tsc && node scripts/postbuild.mjs",
    "prepublishOnly": "npm run build",
    "init": "tsx bin/agent-env.ts init",
    "route": "tsx bin/agent-env.ts route"
  },
  "dependencies": {
    "@agent-env/shared": "*",
    "@clack/prompts": "^0.9.0",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
